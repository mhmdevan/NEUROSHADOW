# Local emergency demo database. This works with the default Prisma SQLite schema.
DATABASE_URL="file:./dev.db"

# Production PostgreSQL example.
# To use PostgreSQL, set DATABASE_URL below and run the postgres schema scripts:
# pnpm prisma:generate:postgres
# pnpm prisma:migrate:postgres
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/neuroshadow?schema=public"

NEXT_PUBLIC_APP_MODE="research-demo"

# Cookie hardening. Production defaults to secure cookies unless explicitly disabled.
NEUROSHADOW_SECURE_COOKIES="false"
NEUROSHADOW_COOKIE_SAMESITE="lax"
